# ===== HTTP 代理（可选）=====
# 当 VPS / 本机被某些交易所封锁时，可以让所有交易所 REST 请求走本地代理转发。
# 典型场景：本机运行 clash/v2ray，混合端口监听 127.0.0.1:7890。
# 留空则直连。HTTP 与 SOCKS5 都被 httpx 支持。
# HTTP_PROXY_URL=http://127.0.0.1:7890
# HTTP_PROXY_URL=socks5://127.0.0.1:7890

# ===== Binance API（合约）=====
# 仅在需要私有数据时配置；公开 K 线/Trades 不需要
BINANCE_API_KEY=
BINANCE_API_SECRET=

# 公开 REST 基址（默认主网；fapi.binance.com 在某些 IP 被封禁时改成测试网）
# 主网:   https://fapi.binance.com
# 测试网: https://testnet.binancefuture.com
BINANCE_REST_BASE_URL=https://fapi.binance.com

# ===== Coinglass API =====
# 用于获取 OI 加权资金费率
COINGLASS_API_KEY=

# ===== Telegram 通知 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 应用配置 =====
APP_ENV=development            # development | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
DUCKDB_PATH=./data/pa.duckdb

# ===== 数据采集配置 =====
SYMBOL=BTCUSDT
TIMEFRAMES=1m,5m,15m,1h,4h,1d
COINGLASS_POLL_INTERVAL_SEC=10
OI_POLL_INTERVAL_SEC=60

# ===== Web Server =====
API_HOST=127.0.0.1
API_PORT=8000
