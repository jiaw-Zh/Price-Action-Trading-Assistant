# ===== Binance API（合约）=====
# 仅在需要私有数据时配置；公开 K 线/Trades 不需要
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ===== Coinglass API =====
# 用于获取 OI 加权资金费率
COINGLASS_API_KEY=

# ===== Telegram 通知 =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== 应用配置 =====
APP_ENV=development            # development | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
DUCKDB_PATH=./data/pa.duckdb

# ===== 数据采集配置 =====
SYMBOL=BTCUSDT
TIMEFRAMES=1m,5m,15m,1h,4h,1d
COINGLASS_POLL_INTERVAL_SEC=10
OI_POLL_INTERVAL_SEC=60

# ===== Web Server =====
API_HOST=127.0.0.1
API_PORT=8000
